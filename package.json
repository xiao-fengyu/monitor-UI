{
  "name": "monitor-ui",
  "version": "1.0.0",
  "description": "OpenClaw 中文监控面板 - 日志聚合 · 监控告警 · 自动化备份",
  "main": "server/index.js",
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "start": "node server/index.js",
    "backup": "node server/utils/backup.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.12",
    "antd": "^5.12.5",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "zustand": "^4.4.7",
    "axios": "^1.6.5",
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}